# Synthetic Linux-compatible kernel config hints for LTP on Asterinas.
#
# Asterinas is not built from the Linux kernel's Kconfig tree, but a subset of
# LTP helpers expects a parseable kernel .config to exist. This file provides
# only conservative compatibility hints that are known to be available in the
# guest environment.
CONFIG_PROC_FS=y
CONFIG_EXT2_FS=y
CONFIG_EXFAT_FS=y
# CONFIG_POSIX_AUX_CLOCKS is not set
