         status_flags: StatusFlags,
     ) -> Result<usize> {
         if status_flags.contains(StatusFlags::O_DIRECT) {
-            self.read_direct_at(offset, writer)
+            self.read_direct_at_with_flags(offset, writer, status_flags)
