--- a/test/initramfs/src/syscall/ltp/testcases/all.txt
+++ b/test/initramfs/src/syscall/ltp/testcases/all.txt
@@ -353,8 +353,8 @@ fcntl30
 fcntl30_64
 fcntl31
 fcntl31_64
-# fcntl32
