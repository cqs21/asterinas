+            InodeType::Dir => RamInode::new_dir(&fs, mode, uid, gid, &self.this),
             _ => {
                 panic!("unsupported inode type");
             }
diff --git a/test/initramfs/src/syscall/ltp/debug/family-open-10.md b/test/initramfs/src/syscall/ltp/debug/family-open-10.md
