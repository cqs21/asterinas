+        let inherit_parent_gid = inner.file_perm().contains(FilePerm::S_ISGID);
+        let inherited_gid = inherit_parent_gid.then(|| inner.gid());
+        if inherit_parent_gid && inode_type == InodeType::Dir {
+            file_perm |= FilePerm::S_ISGID;
+        }
