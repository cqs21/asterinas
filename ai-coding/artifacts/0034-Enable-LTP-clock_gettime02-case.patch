 RUN_ID=$(date +%Y%m%d-%H%M%S)-$$
 RUN_ARTIFACT_DIR="$ARTIFACTS_ROOT/run-$RUN_ID"
@@ -66,6 +67,10 @@ print_case_bucket() {
 cleanup_workdir
