+/// Streaming gzip decompressor backed by `miniz_oxide`.
+struct GzipReader<'a> {
+    input: &'a [u8],
+    state: Box<InflateState>,
+    finished: bool,
+}
+
+impl<'a> GzipReader<'a> {
+    fn new(buf: &'a [u8]) -> core::result::Result<Self, &'static str> {
+        let offset = Self::skip_gzip_header(buf)?;
+        Ok(Self {
+            input: &buf[offset..],
+            state: InflateState::new_boxed(DataFormat::Raw),
+            finished: false,
+        })
+    }
+
+    /// Parses and skips the gzip header, returning the byte offset of the
+    /// deflate stream.
+    fn skip_gzip_header(buf: &[u8]) -> core::result::Result<usize, &'static str> {
+        if buf.len() < 10 || buf[0] != 0x1F || buf[1] != 0x8B {
+            return Err("not a gzip stream");
+        }
+        if buf[2] != 8 {
+            return Err("unsupported compression method");
+        }
+
+        let flags = buf[3];
+        let mut pos = 10;
+
+        // FEXTRA
+        if flags & 0x04 != 0 {
+            if pos + 2 > buf.len() {
+                return Err("truncated gzip header (FEXTRA length)");
+            }
+            let xlen = u16::from_le_bytes([buf[pos], buf[pos + 1]]) as usize;
+            pos += 2 + xlen;
+        }
+        // FNAME
+        if flags & 0x08 != 0 {
+            while pos < buf.len() && buf[pos] != 0 {
+                pos += 1;
+            }
+            pos += 1; // skip null terminator
+        }
+        // FCOMMENT
+        if flags & 0x10 != 0 {
+            while pos < buf.len() && buf[pos] != 0 {
+                pos += 1;
+            }
+            pos += 1;
+        }
+        // FHCRC
+        if flags & 0x02 != 0 {
+            pos += 2;
+        }
+
+        if pos > buf.len() {
+            return Err("truncated gzip header");
+        }
+        Ok(pos)
+    }
+}
+
+impl Read for GzipReader<'_> {
+    fn read(&mut self, buf: &mut [u8]) -> no_std_io2::io::Result<usize> {
+        if self.finished || buf.is_empty() {
+            return Ok(0);
+        }
+
+        let result =
+            miniz_oxide::inflate::stream::inflate(&mut self.state, self.input, buf, MZFlush::None);
+
+        self.input = &self.input[result.bytes_consumed..];
+
+        match result.status {
+            Ok(MZStatus::Ok) => Ok(result.bytes_written),
+            Ok(MZStatus::StreamEnd) => {
+                self.finished = true;
+                Ok(result.bytes_written)
+            }
+            _ => Err(no_std_io2::io::Error::new(
+                no_std_io2::io::ErrorKind::InvalidData,
+                "gzip decompression error",
+            )),
+        }
+    }
+}
